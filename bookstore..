<!DOCTYPE html>
<html>
    <head>
        <title>Book Store</title>
    </head>
    <style>
A
        *{
          margin: 0;
          padding: 0;
          box-sizing: border-box;
          font-family: 'Times New Roman', Times, serif;
        }

        body{
            background: #0f172a;
            color: white;
        }

        /* Navbar */

        .navbar{
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: rgba(15, 23, 42, 0.95);
            position: sticky;
            top: 0;
            z-index: 100%;
        }

        .navbar h1{
            color: #38bdf8;
            font-size: 32px;
        }

        .cart{
            background: #38bdf8;
            color:#000;
            padding: 10px 18px;
            border-radius: 30px;
            font-weight: bold;
        }

        .cart span{
            background: #000;
            color: white;
            padding: 3px 8px;
            border-radius: 50%;
            margin-left: 5px;
        }


        /* Hero */
        .hero{
            height: 60vh;
            background: url(book3.webp) center/cover no-repeat;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .overlay{
            background: rgba(0, 0, 0, 0.6);
            padding: 50px;
            text-align: center;
            border-radius: 20px;
        }

        .overlay h2{
            font-size: 52px;
            margin-bottom: 15px;
        }

        .overlay p{
            font-size: 20px;
            margin-bottom: 20px;
        }

        .overlay button{
            padding: 14px 30px;
            border: none;
            background: #38bdf8;
            color: black;
            font-size: 18px;
            border-radius: 40px;
            cursor: pointer;
            transition: 0.3s;
        }

        .overlay button:hover{
            transform: scale(1.05);
        }


        /* Books */

        .books-container{
            padding: 60px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 35px;
        }

        .book-card{
            background: #1e293b;
            border-radius: 20px;
            overflow: hidden;
            transition: 0.4s;
            box-shadow: 0 10px 25px rgba(0,0,0.4);
        }

        .book-card:hover{
            transform: translateY(-10px);
        }

        .book-card img{
            width: 100%;
            height: 320px;
            object-fit: cover;
        }

        .book-info{
            padding: 20px;
        }

        .book-info h3{
            font-size: 24px;
            margin-bottom: 8px;
        }

        .book-info p{
            color: #cbd5e1;
            margin-bottom: 15px;
        }

        .price{
            color: #38bdf8;
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .button{
            display: flex;
            gap: 10px;
        }

        .buy-btn,
        .read-btn{
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 16px;
            transition: 0.3s;
        }

        .buy-btn:{
            background: #38bdf8;
            color: black;
            font-weight: bold;
            
        }

        .buy-btn:hover{
            background: #0ea5e9;
        }

        .read-btn{
            background: transparent;
            border: 2px solid #38bdf8;
            color: white;
        }

        .read-btn:hover{
            background: #383838;
            color: black;
        }


        /*  Responsive */

        @media (max-width:768px){
            .overlay h2 {
                font-size: 36px;
            }

            .books-container{
                padding: 20px;
            }

            .navbar{
                padding: 20px;
            }
        }



    </style>


    <body>
        <!--Navbar-->
        <nav class="navbar">
            <h1> 📚BookVerse</h1>

            <div class="cart">
              🛒  Cart <span>0</span>
            </div>
        </nav>


        <!--Hero Section-->
        <section class="hero">
            <div class="overlay">
                <h2> Discover Amazing Books</h2>
                <p> Buy and read your favourite books online</p>
                <button>Explore Now</button>
            </div>
        </section>

        <!--Books-->
        <div class="books-container">

            <!--Book 1-->
            <div class="book-card">
                <img
                src="download.jpg"
                alt="The Silent Forest"/>

                <div class="book-info">
                    <h3>The Silent Forest</h3>
                    <p>Emma Woods</p>
                    <div class="price"> $12</div>
                    
                    <div buttons>
                        <button class="buy-btn"> Buy</button>
                        <button class="read-btn"> Read</button>
                    </div>
                </div>
            </div>


             <!--Book 2-->
            <div class="book-card">
                <img
                src="book 7.jpg"
                alt="Future of AI"/>

                <div class="book-info">
                    <h3>Future of AI</h3>
                    <p>Smith</p>
                    <div class="price"> $18</div>
                    
                    <div buttons>
                        <button class="buy-btn"> Buy</button>
                        <button class="read-btn"> Read</button>
                    </div>
                </div>
            </div>


            <!--Book 3-->
            <div class="book-card">
                <img
                src="book2.jpg" alt="Ocean Dreams"/>

                <div class="book-info">
                    <h3>Ocean Dreams</h3>
                    <p>S0phia Blue</p>
                    <div class="price"> $15</div>
                    
                    <div buttons>
                        <button class="buy-btn"> Buy</button>
                        <button class="read-btn"> Read</button>
                    </div>
                </div>
            </div>


        </div>


    </body>
</html>
